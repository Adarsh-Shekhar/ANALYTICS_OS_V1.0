# ANALYTICS_OS_V1.0 Environment Configuration
# Copy this file to .env and fill in your actual values

# Required: Groq API Key for LLaMA 3.3 70B model
# Get yours free at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: Server configuration
# HOST=0.0.0.0
# PORT=8000

# Optional: Database configuration
# DUCKDB_PATH=app_data.duckdb

# Optional: LangGraph recursion limit (max SQL self-correction retries)
# RECURSION_LIMIT=5